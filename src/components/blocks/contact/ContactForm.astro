---
import Button from "@/starwind/button";
import {
  Dialog,
  DialogTrigger,
  DialogContent,
  DialogHeader,
  DialogFooter,
  DialogTitle,
  DialogDescription,
  DialogClose,
} from "@/starwind/dialog";
---

<div class="col-span-4 md:col-span-8 lg:col-span-6" data-scroll-animate>
  <div class="space-y-6 bg-brand-100/50 p-4 md:p-8 lg:p-12">
    <Dialog>
      <DialogTrigger asChild>
        <Button id="open-dialog-trigger" class="hidden">Open Dialog</Button>
      </DialogTrigger>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Message Sent!</DialogTitle>
          <DialogDescription>
            Thank you for contacting us. Your message has been successfully
            sent. We will get back to you soon.
          </DialogDescription>
        </DialogHeader>
        <div class="py-4 text-green-600 font-semibold text-center" role="alert">
          Your message was sent successfully.
        </div>
        <DialogFooter>
          <DialogClose asChild>
            <Button variant="outline">Close</Button>
          </DialogClose>
        </DialogFooter>
      </DialogContent>
    </Dialog>

    <h2 class="mb-8 text-2xl font-semibold" data-scroll-animate>Ask a Question</h2>

    <form class="space-y-6" method="POST" data-scroll-animate id="contact-form" novalidate>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label for="contact-name" class="font-medium text-gray-700">Your Name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            placeholder="Your Name"
            required
            aria-required="true"
            class="as-form-control"
          />
        </div>

        <div class="space-y-2">
          <label for="contact-email" class="font-medium text-gray-700">Your Email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            placeholder="Your Email"
            required
            aria-required="true"
            class="as-form-control"
          />
        </div>
      </div>

      <div class="space-y-2">
        <label for="contact-subject" class="font-medium text-gray-700">Subject</label>
        <input
          id="contact-subject"
          name="subject"
          type="text"
          required
          minlength="12"
          placeholder="Subject"
          aria-required="true"
          class="as-form-control"
        />
      </div>

      <div class="space-y-2">
        <label for="contact-message" class="font-medium text-gray-700">Your Message</label>
        <textarea
          id="contact-message"
          name="message"
          required
          minlength="40"
          maxlength="500"
          placeholder="Type Your Message"
          rows={6}
          aria-required="true"
          class="as-form-textarea resize-none"></textarea>
      </div>

      <Button type="submit" class="btn--primary w-full md:w-auto">
        Send Mail
      </Button>
    </form>
  </div>
</div>

<script type="module">
  document
    .getElementById("contact-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target;
      const formData = new FormData(form);

      const res = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      const result = await res.json();
      if (result.success) {
        document.getElementById("open-dialog-trigger")?.click();
        form.reset();
      } else {
        alert("There was an error sending your message. Please try again.");
      }
    });
</script>
