---
import { Image } from "astro:assets";
import SectionHeader from "@/components/atoms/SectionHeader.astro";

import furniture1 from "@/assets/images/furniture/1.png";
import furniture2 from "@/assets/images/furniture/2.png";
import furniture3 from "@/assets/images/furniture/3.png";
import furniture4 from "@/assets/images/furniture/4.png";

const featuredProducts = [
  {
    image: furniture1,
    title: "Cantilever chair",
    code: "Y523201",
    price: "$42.00",
    colors: ["bg-teal-300", "bg-primary-600", "bg-blue-900"],
  },
  {
    image: furniture2,
    title: "Cantilever chair",
    code: "Y523201",
    price: "$42.00",
    colors: ["bg-teal-300", "bg-primary-600", "bg-blue-900"],
  },
  {
    image: furniture3,
    title: "Cantilever chair",
    code: "Y523201",
    price: "$42.00",
    colors: ["bg-teal-300", "bg-primary-600", "bg-blue-900"],
  },
  {
    image: furniture4,
    title: "Cantilever chair",
    code: "Y523201",
    price: "$42.00",
    colors: ["bg-teal-300", "bg-primary-600", "bg-blue-900"],
  },
];
---

<!-- START - Featured Products -->
<section class="my-10">
  <div class="xl:container px-6 mx-auto">
    <SectionHeader> Featured Products </SectionHeader>

    <!-- Component: carousel -->
    <div class="relative overflow-hidden w-full" id="glide-featured">
      <!-- Slides -->
      <div data-glide-el="track">
        <ul
          class="whitespace-no-wrap flex-no-wrap [backface-visibility: hidden] [transform-style: preserve-3d] [touch-action: pan-Y] [will-change: transform] relative flex w-full overflow-hidden p-0"
        >
          {
            featuredProducts.map((product) => (
              <li>
                <!-- Component: E-commerce card -->
                <article
                  class="group overflow-hidden bg-white rounded-lg shadow-[0px_0px_16px_0px_rgba(0,0,0,0.05)] text-slate-500 shadow-slate-100 transition-colors"
                >
                  <!-- Image -->
                  <figure
                    class="relative overflow-hidden aspect-square w-full bg-tertiary-50 flex items-center justify-center"
                  >
                    <ul class="list-none inline-flex absolute z-10 -top-3 left-3 opacity-0 transition-all group-hover:opacity-100 group-hover:top-3">
                      <li>
                        <a
                          href="#"
                          aria-label="Add to cart"
                          class="inline-flex w-8 h-8 items-center justify-center rounded-full text-blue-500 transition-colors hover:bg-tertiary-200 hover:text-blue-800"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-4 h-4"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"
                            ></path>
                          </svg>
                        </a>
                      </li>
                      <li>
                        <a
                          href="#"
                          aria-label="Add to wishlist"
                          class="inline-flex w-8 h-8 items-center justify-center rounded-full text-blue-500 transition-colors hover:bg-tertiary-200 hover:text-blue-800"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-4 h-4"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
                            ></path>
                          </svg>
                        </a>
                      </li>
                      <li>
                        <a
                          href="#"
                          aria-label="Quick view"
                          class="inline-flex w-8 h-8 items-center justify-center rounded-full text-blue-500 transition-colors hover:bg-tertiary-200 hover:text-blue-800"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-4 h-4"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"
                            ></path>
                          </svg>
                        </a>
                      </li>
                    </ul>

                    <Image
                      src={product.image}
                      alt={`${product.title} - Modern furniture`}
                      width={400}
                      height={400}
                      format="webp"
                      quality={80}
                      loading="lazy"
                      class="transition-transform duration-300 scale-[0.6] group-hover:scale-75"
                      widths={[200, 400, 600]}
                      sizes={`(max-width: 640px) 200px, (max-width: 1024px) 300px, 400px`}
                    />

                    <!-- Component: Base primary basic button -->
                    <button
                      class="absolute bottom-0 opacity-0 inline-flex items-center justify-center h-10 gap-2 px-5 font-lato text-sm font-medium tracking-wide text-white transition-all duration-300 rounded group-hover:opacity-100 group-hover:bottom-8 focus-visible:outline-none whitespace-nowrap bg-emerald-500 hover:bg-emerald-600 focus:bg-emerald-700 disabled:cursor-not-allowed disabled:border-emerald-300 disabled:bg-emerald-300 disabled:shadow-none"
                    >
                      <span>View Details</span>
                    </button>
                  </figure>
                  <!-- Body-->
                  <div
                    class="p-6 text-center transition-colors group-hover:bg-blue-800"
                  >
                    <header class="mb-4">
                      <h3
                        class="text-xl font-bold text-primary-500 group-hover:text-white"
                      >
                        {product.title}
                      </h3>
                      <ul class="list-none">
                        <li class="inline-block bg-teal-300 rounded-md h-1 w-4">
                        </li>
                        <li class="inline-block bg-primary-600 rounded-md h-1 w-4">
                        </li>
                        <li
                          class="inline-block bg-blue-900 group-hover:bg-yellow-200 rounded-md h-1 w-4"
                        >
                        </li>
                      </ul>
                    </header>
                    <p class="text-blue-900 font-bold mb-3 group-hover:text-white">
                      Code - {product.code}
                    </p>
                    <p class="text-blue-900 group-hover:text-white">{product.price}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
      <!-- Indicators -->
      <div
        class="flex items-center justify-center w-full gap-2 mt-8"
        data-glide-el="controls[nav]"
      >
        {
          featuredProducts.map((_, idx) => (
            <button class="group" data-glide-dir={`=${idx}`} aria-label={`Go to slide ${idx + 1}`}>
              <span
                class="block h-1 w-4 transition-colors duration-300 rounded-full opacity-70 bg-primary-200 focus:outline-none focus:ring-2 focus:ring-primary-500"
              ></span>
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>
<!-- END - Featured Products -->
